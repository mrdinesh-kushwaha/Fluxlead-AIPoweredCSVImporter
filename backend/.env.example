# ==============================================================
# This is a TEMPLATE only — copy to `.env` for local dev.
# In production (Render), these are set in the Render Dashboard
# under Environment, NOT in a file. Same variable names, same
# code — only the source of the values changes per environment.
# ==============================================================

# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database (Neon Postgres) - optional, app runs stateless if omitted
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/growease?sslmode=require

# AI Provider: "openai" | "gemini" | "anthropic" | "groq"
AI_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Batch size for AI extraction
AI_BATCH_SIZE=20
AI_MAX_RETRIES=3

# Upload limits
MAX_FILE_SIZE_MB=5
